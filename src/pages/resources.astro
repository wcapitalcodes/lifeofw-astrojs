---
import AchievementCard from '~/components/AchievementCard.astro';
import AdvisorCard from '~/components/AdvisorCard.astro';
import PageHeader from '~/components/PageHeader.astro';
import TeamCard from '~/components/TeamCard.astro';
import PageLayout from '~/layouts/PageLayout.astro';

const pageTitle = 'Resources';
const pageSubtitle =
  "Explore our engaging articles and powerful financial tools, including retirement calculators, on W Vault's resource page! Discover how to take charge of your financial future today!";

const metadata = {
  title: 'Financial Resources & Tools | Calculators & Articles | Life of W',
  description: "Access Wahine Capital's comprehensive collection of financial resources, calculators, guides, and educational articles designed specifically for Malaysian women. Discover practical tools to enhance your financial literacy and take charge of your financial future.",
  keywords: "financial resources Malaysia, women finance tools, financial calculators Malaysia, retirement planning tools, financial articles for women, women financial education resources, personal finance guides, investment resources Malaysia, money management tools, financial literacy resources, Malaysian women finance resources",
  openGraph: {
    site_name: 'Financial Resources | Life of W',
    type: 'website',
    images: [
      {
        url: '/images/resources-og-image.jpg',
        width: 1200,
        height: 630,
        alt: 'Financial Resources & Tools for Malaysian Women - Life of W'
      }
    ]
  },
  twitter: {
    card: 'summary_large_image',
    site: '@wahine_capital',
    creator: '@wahine_capital'
  }
};
---

<PageLayout
  metadata={metadata}
  hasPageHeader={true}
  pageTitle={pageTitle}
  pageSubtitle={pageSubtitle}
  highlightedTitleText="Resources"
>
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-10 md:space-x-16 flex flex-col md:flex-row items-center space-y-10 md:space-y-0 py-10"
  >
    <div class="flex flex-col items-center justify-center ">
      <img src="https://assets.lifeofw.com/images/calculator-article.png" alt="" class="w-lg" />
    </div>
  </div>
</PageLayout>
