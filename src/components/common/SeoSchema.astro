---
// SeoSchema.astro - Component for implementing structured data schemas
interface Props {
  type: 'Organization' | 'WebSite' | 'WebPage' | 'Article' | 'Product' | 'FAQPage' | 'BreadcrumbList';
  data: Record<string, any>;
}

const { type, data } = Astro.props;

// Base schema with @context
const schemaData = {
  '@context': 'https://schema.org',
  '@type': type,
  ...data
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)}></script> 