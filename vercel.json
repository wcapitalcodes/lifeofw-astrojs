{
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "framework": "astro",
  "headers": [
    {
      "source": "/_astro/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ]
}